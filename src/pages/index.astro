    <style>
      /* ===== Tokens: linear.app system, Oleafly app-blue accent ===== */
      :root {
        --brand: #2563eb;
        --brand-hover: #3b82f6;
        --brand-text: #60a5fa;
        --bg: #08090a;
        --bg-deep: #060607;
        --surface: #0a0a0a;
        --surface-2: #191a1c;
        --text: #f7f8f8;
        --muted: #8a8f98;
        --line: rgba(255, 255, 255, 0.08);
        --line-strong: rgba(255, 255, 255, 0.14);
        --green: #34b44a;
        --red: #eb5757;
        --radius-sm: 4px;
        --radius-md: 6px;
        --radius-lg: 8px;
        --shadow-popup: 0 4px 16px rgba(0, 0, 0, 0.4);
        --shadow-modal: 0 16px 48px rgba(0, 0, 0, 0.5);
        --font: "Inter", "Inter Fallback", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 76px;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font);
        font-size: 15px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      ::selection {
        background: rgba(37, 99, 235, 0.4);
      }
      .container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 24px;
      }
      .rel {
        position: relative;
      }
      code {
        font-family: var(--mono);
        font-size: 0.86em;
        background: var(--surface-2);
        border: 1px solid var(--line);
        border-radius: var(--radius-sm);
        padding: 1px 5px;
        color: #d6d9e0;
      }
      a {
        color: inherit;
      }
      .skip {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--brand);
        color: #fff;
        padding: 8px 12px;
        border-radius: var(--radius-md);
        z-index: 100;
      }
      .skip:focus {
        left: 12px;
        top: 12px;
      }

      /* ===== Buttons ===== */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        border-radius: var(--radius-md);
        font-weight: 500;
        text-decoration: none;
        white-space: nowrap;
        transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
      }
      .btn-sm {
        font-size: 13px;
        padding: 6px 12px;
      }
      .btn-lg {
        font-size: 14px;
        padding: 10px 18px;
      }
      .btn-primary {
        background: #f7f8f8;
        color: #08090a;
        border: 1px solid transparent;
      }
      .btn-primary:hover {
        background: #ffffff;
      }
      .btn-ghost {
        background: transparent;
        color: #d6d9e0;
        border: 1px solid var(--line-strong);
      }
      .btn-ghost:hover {
        background: rgba(255, 255, 255, 0.04);
        color: #fff;
      }

      /* ===== Nav ===== */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(8, 9, 10, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid transparent;
        transition: border-color 150ms ease;
      }
      .nav.scrolled {
        border-bottom-color: var(--line);
      }
      .nav-inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 24px;
        height: 56px;
        display: flex;
        align-items: center;
        gap: 24px;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        font-size: 15px;
        letter-spacing: -0.01em;
        text-decoration: none;
        color: #fff;
      }
      .nav-links {
        display: flex;
        gap: 4px;
        margin-left: 8px;
      }
      .nav-links a {
        font-size: 13px;
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        padding: 6px 10px;
        border-radius: var(--radius-md);
        transition: color 150ms ease, background 150ms ease;
      }
      .nav-links a:hover {
        color: #fff;
        background: rgba(255, 255, 255, 0.04);
      }
      .nav-cta {
        margin-left: auto;
        display: flex;
        gap: 8px;
      }

      /* ===== Hero ===== */
      .hero {
        position: relative;
        padding: 108px 0 40px;
        overflow: hidden;
        text-align: left;
      }
      .hero-glow {
        position: absolute;
        inset: -30% -20% auto;
        height: 620px;
        background: radial-gradient(720px 360px at 30% 12%, rgba(37, 99, 235, 0.12), transparent 70%);
        pointer-events: none;
      }
      .pill {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.02);
        border-radius: 999px;
        padding: 5px 12px;
        margin-bottom: 28px;
        transition: color 150ms ease, border-color 150ms ease;
      }
      .pill:hover {
