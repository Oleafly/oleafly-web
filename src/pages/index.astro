---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://oleafly.com/" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Oleafly" />
    <meta property="og:title" content="Oleafly: Write LaTeX like you write code" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://oleafly.com/" />
    <meta property="og:image" content="https://oleafly.com/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="The Oleafly editor with LaTeX source and a live PDF preview" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="keywords" content="LaTeX editor, offline LaTeX editor, Overleaf alternative, LaTeX resume builder, ATS resume checker, AI LaTeX assistant, free LaTeX app Mac Windows Linux" />
    <meta name="twitter:title" content="Oleafly: Write LaTeX like you write code" />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://oleafly.com/og.png" />

    <link
      rel="preload"
      as="image"
      imagesrcset={heroPreload.srcSet.attribute}
      imagesizes="(max-width: 760px) 94vw, 1080px"
      fetchpriority="high"
    />
    <link rel="preload" href="/fonts/inter-var-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/jbmono-var-latin.woff2" as="font" type="font/woff2" crossorigin />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    <a class="skip" href="#main">Skip to content</a>
    <ScrollProgress client:idle className="h-[2px]" />

    <header class="nav" id="nav">
      <div class="nav-inner">
        <a class="brand" href="/">
          <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
            <path
              d="M21 2C6 2 4 16 3 22h1.998c.666-3.333 2.333-5.166 5.002-5.5 4-.5 7-4 8-7l-1.5-1 1-1c1-1 2.004-2.5 3.5-5.5z"
              fill="#34B44A"></path>
          </svg>
          <span>Oleafly</span>
        </a>
        <nav class="nav-links" aria-label="Main">
          <a href="#templates">Features</a>
          <a href="/tools/">Tools</a>
          <a href="/templates/">Templates</a>
          <a href="/deadlines/">Deadlines</a>
          <a href="/blog/">Blog</a>
          <a href="/docs/overview/">Docs</a>
          <a href={GITHUB} target="_blank" rel="noopener noreferrer">GitHub</a>
        </nav>
        <div class="nav-cta">
          <a class="btn btn-ghost btn-sm stars" href={GITHUB} target="_blank" rel="noopener noreferrer">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path
                d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"
              ></path>
            </svg>
            <span>Star on GitHub</span><span class="stars-count" id="stars-count"></span>
          </a>
        </div>
      </div>
    </header>

    <main id="main">
      <!-- ============================== Hero ============================== -->
      <section class="hero">
        <div class="hero-glow" aria-hidden="true"></div>
        <DotPattern
          width={24}
          height={24}
          cr={1}
          className="fill-white/[0.12] [mask-image:radial-gradient(85%_60%_at_50%_18%,white,transparent)]"
        />
        <div class="container">
          <a class="pill" href={GITHUB} target="_blank" rel="noopener noreferrer">
            <span class="pill-dot" aria-hidden="true"></span>
            <AnimatedShinyText shimmerWidth={120}>
              Free · Open source · AGPL-3.0 · Mac · Windows · Linux
            </AnimatedShinyText>
          </a>
          <h1>
            <span class="h1-line">
              Write&nbsp;<span class="rotate-slot">
                <WordRotate
                  client:load
                  words={["research papers", "resumes", "theses", "grant proposals"]}
                  wordClassNames={[
                    "bg-gradient-to-r from-[#60a5fa] to-[#2563eb] bg-clip-text text-transparent",
                    "bg-gradient-to-r from-[#4ec46a] to-[#34b44a] bg-clip-text text-transparent",
                    "bg-gradient-to-r from-[#a78bfa] to-[#8b5cf6] bg-clip-text text-transparent",
                    "bg-gradient-to-r from-[#f7bc55] to-[#f59e0b] bg-clip-text text-transparent",
                  ]}
                  duration={2600}
                  motionProps={{
                    initial: { opacity: 0, y: -14 },
                    animate: { opacity: 1, y: 0 },
                    exit: { opacity: 0, y: 14 },
                    transition: { duration: 0.22, ease: "easeOut" },
                  }}
                  className="h1-word"
                />
              </span>
            </span>
            <span class="h1-line">like you write code.</span>
          </h1>
          <p class="lede">
            Oleafly is an AI-native LaTeX studio that runs <Highlighter client:load action="underline" color="#2563eb" strokeWidth={2} isView>entirely on your machine</Highlighter>. No account, no cloud, no TeX install. Every compile becomes a Git commit, and the AI
            verifies its own edits by reading the PDF.
          </p>
          <div class="hero-actions">
            <RainbowLink href={RELEASES} label="Download for free" size="lg" />
            <a class="btn btn-ghost btn-lg" href="/docs/overview/">Read the docs</a>
          </div>
          <figure class="shot shot-hero">
            <Image
              src={heroEditor}
              alt="The Oleafly editor: LaTeX source on the left, the compiled PDF building live on the right"
              widths={[720, 1200, 1800]}
              sizes="(max-width: 760px) 94vw, 1080px"
              loading="eager"
              fetchpriority="high"
            />
            <BorderBeam
              client:load
              size={240}
              duration={10}
              borderWidth={1.5}
              colorFrom="#2563eb"
              colorTo="#34b44a"
            />
          </figure>
          <div class="chips-marquee" aria-label="Highlights">
            <Marquee pauseOnHover className="p-0 [--duration:30s] [--gap:0.5rem]">
              <span class="chip">Works fully offline</span>
              <span class="chip">Plain <code>.tex</code> files on your disk</span>
              <span class="chip">Bring your own AI, or none</span>
              <span class="chip">MCP server built in</span>
              <span class="chip">Tagged, accessible PDF export</span>
            </Marquee>
          </div>
        </div>
      </section>

      <!-- ============== Feature stack: sticky 3D card deck ============== -->
      <div class="stack">
      <!-- ========================= Templates ========================= -->
      <section class="stack-card" id="templates">
        <div class="container">
          <p class="eyebrow">Templates</p>
          <h2 class="h2-rotate-line">
            Start from a real&nbsp;<span class="rotate-slot rotate-slot-h2">
              <WordRotate
                client:visible
                words={["resume.", "IEEE paper.", "thesis.", "Beamer deck.", "poster.", "cover letter."]}
                wordClassNames={[
                  "text-[#60a5fa]",
                  "text-[#4ec46a]",
                  "text-[#a78bfa]",
                  "text-[#f7bc55]",
                  "text-[#f472b6]",
                  "text-[#22d3ee]",
                ]}
                duration={2200}
                motionProps={{
                  initial: { opacity: 0, y: -12 },
                  animate: { opacity: 1, y: 0 },
                  exit: { opacity: 0, y: 12 },
                  transition: { duration: 0.22, ease: "easeOut" },
                }}
                className="h2-word"
              />
            </span>
          </h2>
          <p class="sub">
            ATS-friendly resumes, IEEE and ACM papers, theses, books, Beamer decks, research posters,
            letters, browsable by category with live previews. Templates that use premium
            open-source fonts fetch them on demand and copy them into the project, so every document
            stays self-contained and compiles offline.
          </p>
          <figure class="shot shot-wide">
            <Image
              src={projectTemplates}
              alt="Oleafly's template gallery with categories, search, and live previews"
              widths={[720, 1200, 1800]}
              sizes="(max-width: 980px) 94vw, 1080px"
              loading="lazy"
            />
          </figure>
        </div>
      </section>

      <!-- ============================ Git ============================ -->
      <section class="stack-card" id="git">
        <div class="container">
          <p class="eyebrow">Version control</p>
          <h2>Every compile is a Git commit.</h2>
          <p class="sub">
            Every project is a real Git repo on your disk. Oleafly commits automatically after each
            successful compile and shortly after you stop typing, so history, diffs, and one-click
            restore are just <em>there</em>. No plugin, no setup, no
            <code>resume_final_v3_FINAL.tex</code>.
          </p>
          <div class="split">
            <ul class="ticks">
              <li>Undo a paragraph from yesterday without hunting for it</li>
              <li>Compare any two versions side by side</li>
              <li>Branch your resume before every interview</li>
              <li>Push to GitHub with one click, and <code>git log</code> works from a terminal too</li>
            </ul>
            <figure class="shot">
              <Image
                src={gitDiff}
                alt="Side-by-side diff of a past version of a document in Oleafly"
