      @media (max-width: 640px) {
        .nav-links {
          display: none;
        }
        .hero {
          padding-top: 64px;
        }
        .section,
        .velocity,
        .philosophy {
          padding-top: 72px;
        }
        .dl-grid {
          grid-template-columns: 1fr;
        }
        .footer-inner {
          grid-template-columns: 1fr;
        }
        .ai-steps {
          grid-template-columns: 1fr;
        }
        .gauges {
          justify-content: center;
        }
      }
    </style>

    <script>
      // Eased smooth scroll for in-page links (accounts for the sticky nav
      // and the feature stack's sticky geometry).
      const docY = (el) => {
        let y = 0;
        while (el) {
          y += el.offsetTop;
          el = el.offsetParent;
        }
        return y;
      };
      const easeInOutCubic = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);
      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        a.addEventListener("click", (e) => {
          const target = document.querySelector(a.getAttribute("href"));
          if (!target) return;
          e.preventDefault();
          const from = window.scrollY;
          const to = Math.max(0, docY(target) - 72);
          const dur = Math.min(1300, 450 + Math.abs(to - from) * 0.12);
          const t0 = performance.now();
          const step = (now) => {
            const t = Math.min(1, (now - t0) / dur);
            window.scrollTo({ top: from + (to - from) * easeInOutCubic(t), behavior: "instant" });
            if (t < 1) requestAnimationFrame(step);
            else history.replaceState(null, "", a.getAttribute("href"));
          };
          requestAnimationFrame(step);
        });
      });

      // Nav border on scroll.
      const nav = document.getElementById("nav");
      const onScroll = () => nav?.classList.toggle("scrolled", window.scrollY > 8);
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      // Feature stack: as the next card slides up, the pinned card recedes
      // (scale down, tilt back, dim). Skipped for reduced motion.
      const stackCards = [...document.querySelectorAll(".stack-card")];
      const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (stackCards.length && !reduceMotion) {
        const PIN_TOP = 80;
        let ticking = false;
        const update = () => {
          ticking = false;
          const vh = window.innerHeight;
          for (let i = 0; i < stackCards.length; i++) {
            const card = stackCards[i];
            const next = stackCards[i + 1];
            let t = 0;
            if (next && card.getBoundingClientRect().top <= PIN_TOP + 1) {
              const nTop = next.getBoundingClientRect().top;
              t = Math.min(1, Math.max(0, (vh - nTop) / (vh - PIN_TOP)));
            }
            if (t > 0) {
              card.style.transform = `translateY(${-16 * t}px) scale(${1 - 0.055 * t}) rotateX(${4 * t}deg)`;
              card.style.filter = `brightness(${1 - 0.3 * t})`;
            } else {
              card.style.transform = "";
              card.style.filter = "";
            }
          }
        };
        const onStackScroll = () => {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(update);
          }
        };
        window.addEventListener("scroll", onStackScroll, { passive: true });
        window.addEventListener("resize", onStackScroll, { passive: true });
        update();
      }

      // Quill confetti when the reader reaches the very bottom. Fires once
      // per visit, leaf-shaped in Oleafly greens, skipped for reduced motion.
      let confettiFired = false;
      let confettiModule = null;
      const QUILL_PATH =
        "M21 2C6 2 4 16 3 22h1.998c.666-3.333 2.333-5.166 5.002-5.5 4-.5 7-4 8-7l-1.5-1 1-1c1-1 2.004-2.5 3.5-5.5z";
      const GREENS = ["#34B44A", "#4ec46a", "#7ed492", "#2b8f3c"];
      const onBottomScroll = () => {
        if (confettiFired || matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        const remaining = document.documentElement.scrollHeight - window.scrollY - window.innerHeight;
        // prewarm the module as the reader approaches the end
        if (remaining < 1600 && !confettiModule) {
          confettiModule = import("canvas-confetti");
        }
        if (remaining > 24 || !confettiModule) return;
        confettiFired = true;
        confettiModule.then(({ default: confetti }) => {
          const quill = confetti.shapeFromPath({ path: QUILL_PATH });
          const base = {
            shapes: [quill],
            colors: GREENS,
            scalar: 1.7,
            ticks: 240,
            gravity: 0.85,
            drift: 0.3,
            disableForReducedMotion: true,
          };
          confetti({ ...base, particleCount: 60, spread: 70, angle: 60, origin: { x: 0, y: 1 } });
          confetti({ ...base, particleCount: 60, spread: 70, angle: 120, origin: { x: 1, y: 1 } });
          setTimeout(() => {
            confetti({ ...base, particleCount: 40, spread: 100, angle: 90, origin: { x: 0.5, y: 1 } });
          }, 250);
        });
      };
      window.addEventListener("scroll", onBottomScroll, { passive: true });

      // GitHub star count (best-effort; silent on failure or rate limit).
      fetch("https://api.github.com/repos/Oleafly/Oleafly")
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const n = d?.stargazers_count;
          const el = document.getElementById("stars-count");
          if (el && typeof n === "number") {
            el.textContent = n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n);
          }
        })
        .catch(() => {});
    </script>
  </body>
