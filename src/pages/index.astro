        gap: 10px;
      }
      .footer-col .footer-h {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #d6d9e0;
        margin-bottom: 2px;
      }
      .footer-col a {
        font-size: 13px;
        color: var(--muted);
        text-decoration: none;
        transition: color 150ms ease;
        width: fit-content;
      }
      .footer-col a:hover {
        color: #fff;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
