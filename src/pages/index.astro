      }
      h1 {
        position: relative;
        font-size: clamp(2.4rem, 6vw, 4rem);
        font-weight: 600;
        letter-spacing: -0.025em;
        line-height: 1.08;
        margin-bottom: 20px;
      }
      .h1-line {
        display: block;
        background: linear-gradient(180deg, #ffffff 55%, #b8bcc8);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .rotate-slot {
        display: inline-block;
        vertical-align: baseline;
      }
      .rotate-slot :global(div) {
        display: inline-block;
        padding: 0;
        overflow: visible;
        vertical-align: baseline;
      }
      :global(.h1-word) {
        font-size: inherit;
        font-weight: inherit;
        letter-spacing: inherit;
        line-height: inherit;
        white-space: nowrap;
      }
      .lede {
        position: relative;
        max-width: 620px;
        margin: 0 0 32px;
        color: var(--muted);
        font-size: 16.5px;
        line-height: 1.6;
      }
      .hero-actions {
        position: relative;
        display: flex;
        justify-content: flex-start;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 56px;
      }
      .hero-actions :global(a[data-slot="button"]) {
        text-decoration: none;
      }
      .stars {
        gap: 7px;
      }
      .stars svg {
        color: #e8b339;
      }
      .stars-count:not(:empty) {
