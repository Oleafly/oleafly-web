---
// oleafly.com landing page.
//
// Design system: linear.app — near-black #08090A ground, neutral dark
// surfaces, white primary buttons, Oleafly's app blue #2563EB as the accent,
// Inter, tight spacing, radii ≤ 8px. Magic UI components supply the motion:
// DotPattern, AnimatedShinyText, BorderBeam, Marquee, RainbowButton,
// WordRotate, Highlighter, TextReveal, KineticText, VelocityScroll,
// GlyphMatrix, NoiseTexture, FileTree, CodeComparison (build-time shiki),
// AnimatedCircularProgressBar, ScrollProgress.
import { Image, getImage } from "astro:assets";
import heroEditor from "../assets/hero-editor.png";
import gitDiff from "../assets/git-diff.png";
import preflightAts from "../assets/preflight-ats.png";
import projectTemplates from "../assets/project-templates.png";
import { Marquee } from "../components/magicui/marquee";
import { DotPattern } from "../components/magicui/dot-pattern";
import { AnimatedShinyText } from "../components/magicui/animated-shiny-text";
import { BorderBeam } from "../components/magicui/border-beam";
import { RainbowLink } from "../components/RainbowLink";
import { WordRotate } from "../components/magicui/word-rotate";
import { Highlighter } from "../components/magicui/highlighter";
import { KineticText } from "../components/magicui/kinetic-text";
import { GlyphMatrix } from "../components/magicui/glyph-matrix";
import { NoiseTexture } from "../components/magicui/noise-texture";
import { AnimatedCircularProgressBar } from "../components/magicui/animated-circular-progress-bar";
import { ScrollProgress } from "../components/magicui/scroll-progress";
import { GridPattern } from "../components/magicui/grid-pattern";
import { ProjectFileTree } from "../components/ProjectFileTree";
import { BentoSection } from "../components/BentoSection";
import { VelocityStrip } from "../components/VelocityStrip";
import { PhilosophyReveal } from "../components/PhilosophyReveal";
import CodeComparison from "../components/CodeComparison.astro";
import "../styles/magicui.css";

const heroPreload = await getImage({
  src: heroEditor,
  widths: [720, 1200, 1800],
  sizes: "(max-width: 760px) 94vw, 1080px",
  format: "webp",
});

const GITHUB = "https://github.com/Oleafly/Oleafly";
const RELEASES = `${GITHUB}/releases/latest`;

const title = "Oleafly · Free local-first LaTeX editor & AI resume builder for Mac, Windows, Linux";
const description =
  "A free, open-source LaTeX editor and ATS-friendly resume builder that runs fully offline. An Overleaf alternative with real Git history and a built-in AI assistant that compiles and verifies its own edits. No account, no TeX install. Mac, Windows, Linux.";

// Apple and Linux marks from simple-icons; Windows is the classic four panes.
const APPLE_PATH =
